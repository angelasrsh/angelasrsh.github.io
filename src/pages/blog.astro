---
import type { ACTION_ERROR_CODES } from "astro:actions";
import ChipLayout from "../layouts/ChipLayout.astro";
import I18nKeys from "../locales/keys";
import { i18n } from "../locales/translation";
import { GetCategories, GetSortedPosts } from "../utils/content";
import type Tag from "./tags/[tag].astro";

const categories = [...(await GetCategories()).values()].sort();
const posts = [...(await GetSortedPosts()).values()]
const chips = categories.map((category) => {
  return {
    name: category.name,
    slug: category.slug,
    subChip: category.posts.length.toString(),
  };
});
const { page } = Astro.props;

---

<ChipLayout chips={chips} title={i18n(I18nKeys.pages_categories_title)} />
